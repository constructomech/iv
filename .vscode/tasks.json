{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build debug",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "silent",
                "clear": true
            }
        },
        {
            "label": "build release",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--release"
            ],
            "group": "build",
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "silent",
                "clear": true
            }
        },
        {
            "label": "clippy",
            "type": "shell",
            "command": "cargo",
            "args": [
                "clippy",
                "--all-targets",
                "--",
                "-D",
                "warnings"
            ],
            "group": "test",
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "cargo",
            "args": [
                "test",
                "--",
                "--nocapture"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        },
        {
            "label": "test (release)",
            "type": "shell",
            "command": "cargo",
            "args": [
                "test",
                "--release",
                "--",
                "--nocapture"
            ],
            "group": "test",
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        },
        {
            "label": "run release",
            "type": "shell",
            "command": "${workspaceFolder}/target/release/iv.exe",
            "args": [
                "${input:runPath}"
            ],
            "dependsOn": "build release",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "run release (with logging)",
            "type": "shell",
            "command": "${workspaceFolder}/target/release/iv.exe",
            "args": [
                "${input:runPath}",
                "--log"
            ],
            "options": {
                "env": {
                    "IV_DEBUG": "1"
                }
            },
            "dependsOn": "build release",
            "group": "none",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always"
            }
        }
    ],
    "inputs": [
        {
            "id": "runPath",
            "type": "promptString",
            "description": "Path to an image file or folder",
            "default": "U:\\photos\\2025\\12"
        }
    ]
}